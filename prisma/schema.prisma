// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id                    String      @id @default(cuid())
  fullName              String
  email                 String      @unique
  passwordHash          String?     // nullable for OAuth users
  role                  UserRole    @default(VOLUNTEER)
  
  // Email verification
  emailVerified         Boolean     @default(false)
  emailVerifiedAt       DateTime?
  
  // Password management
  passwordChangedAt     DateTime?
  lastLoginAt           DateTime?
  
  // Relations
  volunteer             Volunteer?
  otps                  OTP[]
  
  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([email])
}

// OTP model for authentication
model OTP {
  id        String      @id @default(cuid())
  email     String
  otpHash   String
  purpose   OTPPurpose
  expiresAt DateTime
  used      Boolean     @default(false)
  
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime    @default(now())
  
  @@index([email, purpose])
  @@index([expiresAt])
}

// Volunteer model
model Volunteer {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fullName              String
  email                 String
  phoneNumber           String
  gender                String?
  dateOfBirth           DateTime?
  address               String?
  city                  String?
  state                 String?
  country               String?
  
  skills                String[]    @default([])
  interests             String[]    @default([])
  availability          String[]    @default([])
  
  emergencyContact      String?
  emergencyPhone        String?
  bloodGroup            String?
  occupation            String?
  
  profilePhoto          String?     // URL to image
  joiningDate           DateTime    @default(now())
  status                VolunteerStatus @default(ACTIVE)
  
  // Relations
  eventParticipants     EventParticipant[]
  
  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([status])
}

// Event model
model Event {
  id                    String      @id @default(cuid())
  title                 String
  description           String      @db.Text
  date                  DateTime
  location              String
  category              String
  
  requiredVolunteers    Int         @default(1)
  status                EventStatus @default(UPCOMING)
  
  // Relations
  participants          EventParticipant[]
  
  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  @@index([status])
  @@index([date])
}

// Event Participants (Many-to-Many relationship)
model EventParticipant {
  id                    String      @id @default(cuid())
  
  volunteerId           String
  volunteer             Volunteer   @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  
  eventId               String
  event                 Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  joinedAt              DateTime    @default(now())
  status                ParticipationStatus @default(REGISTERED)
  
  @@unique([volunteerId, eventId])
  @@index([volunteerId])
  @@index([eventId])
}

// Enums
enum UserRole {
  ADMIN
  VOLUNTEER
}

enum OTPPurpose {
  LOGIN
  EMAIL_VERIFICATION
  PASSWORD_RESET
  CHANGE_PASSWORD
}

enum VolunteerStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  DEACTIVATED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum ParticipationStatus {
  REGISTERED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
